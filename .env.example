# Ruchi environment variables. Copy to .env.local for local dev,
# and set the same keys on your Netlify site (Site configuration > Environment variables).

# Supabase (client-side, safe to expose: these are the public anon credentials).
# Find them in your Supabase project under Project Settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# OpenAI (server-side only, used by the Netlify recipe function).
# Scope this to Functions in the Netlify dashboard. Never expose it client-side.
OPENAI_API_KEY=sk-...
